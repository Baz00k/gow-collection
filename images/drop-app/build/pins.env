# Shared gow-collection base image (Fedora). Pinned to a digest published to
# our own GHCR, which (unlike the upstream Fedora registry) retains old digests,
# so this pin never rots. The digest is bumped automatically by the base-image
# update flow whenever a new base is published.
BASE_APP_IMAGE=ghcr.io/baz00k/gow-collection/base:edge@sha256:957ccfbcd7333e4fd05ab00d331c7e8a011526449b36824ebdc2873ca35e3ac7

DROP_APP_VERSION=0.3.4
DROP_APP_RPM_X86_64_URL=https://github.com/Drop-OSS/drop-app/releases/download/v0.3.4/Drop.Desktop.Client-0.3.4-1.x86_64.rpm
DROP_APP_RPM_X86_64_SHA256=a7e18ceca8dfdb10f0ddf28a8502535ef5fdeb70f78cdf644f072a3feecbf40c
DROP_APP_REPO=Drop-OSS/drop-app
