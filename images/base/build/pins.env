# Fedora base image.
# The human-facing tag stays on the maintained Fedora version (rolling) because
# the upstream Fedora registry garbage-collects old digests, so a digest alone
# cannot be re-pulled once a new build is published. To keep builds reproducible
# anyway, BASE_IMAGE_DIGEST records the digest the rolling tag currently resolves
# to, and the Dockerfile builds FROM "${BASE_IMAGE}@${BASE_IMAGE_DIGEST}".
# update/check.sh detects when the rolling tag points at a new digest.
BASE_IMAGE=registry.fedoraproject.org/fedora:44
BASE_IMAGE_DIGEST=sha256:e3a045722ff0775065bf20b79eec12e3b25118d197d0717f539ba7ba84544d03

# Bubblewrap — patched sandboxing tool for container-friendly capability handling
BUBBLEWRAP_VERSION=v0.11.2
BUBBLEWRAP_COMMIT=1b80120ef26a28e065e67f89bfef873f13bdd317
BUBBLEWRAP_REPO=containers/bubblewrap

# gosu — privilege dropping tool for startup handoff
GOSU_VERSION=1.17
GOSU_AMD64_URL=https://github.com/tianon/gosu/releases/download/1.17/gosu-amd64
GOSU_AMD64_SHA256=bbc4136d03ab138b1ad66fa4fc051bafc6cc7ffae632b069a53657279a450de3
